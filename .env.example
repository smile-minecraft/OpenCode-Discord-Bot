# ========================================
# OpenCode Discord Bot 環境變數範本
# ========================================
# 複製此檔案為 .env 並填入實際值
# 不要將 .env 提交到版本控制系統
# ========================================

# ----------------------------------------
# Discord Bot
# ----------------------------------------
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_client_id

# ----------------------------------------
# OpenCode Configuration
# ----------------------------------------
OPENCODE_API_KEY=your_opencode_api_key
OPENCODE_API_URL=http://localhost:3000

# ----------------------------------------
# Project Manager Configuration
# ----------------------------------------
# 專案資料儲存路徑
# PROJECTS_PATH=./data/projects.json
# 允許的基礎路徑列表（多個路徑用冒號分隔，Unix 用 :，Windows 用 ;）
# ALLOWED_PROJECT_PATHS=/home/user/projects:/workspace
# 例如：ALLOWED_PROJECT_PATHS 會限制只能存取這些目錄下的專案

# ----------------------------------------
# Sentry Configuration
# ----------------------------------------
# Sentry DSN - 從 Sentry 專案設定獲取
SENTRY_DSN=
# 環境名稱 (development, staging, production)
SENTRY_ENVIRONMENT=development
# Release 版本 (自動從 package.json 讀取)
SENTRY_RELEASE=
# 追蹤樣本率 (0-1)
SENTRY_TRACES_SAMPLE_RATE=1.0
# 啟用調試模式
SENTRY_DEBUG=false
