# ========================================
# OpenCode Discord Bot 環境變數範本
# ========================================
# 複製此檔案為 .env 並填入實際值
# 不要將 .env 提交到版本控制系統
# ========================================

# ----------------------------------------
# Discord Bot 設定 (必要)
# ----------------------------------------

# Discord Bot Token
# 取得方式：Discord Developer Portal > Bot > Reset Token
# 範例: MTIzNDg2OTgxMjM0NTY3ODkw.xYz123...
DISCORD_TOKEN=your_bot_token_here

# Discord Application Client ID
# 取得方式：Discord Developer Portal > General Information > Application ID
# 範例: 123456789012345678
CLIENT_ID=your_client_id_here

# 測試伺服器 ID (開發用)
# 取得方式：在 Discord 開啟開發者模式 > 伺服器 > 複製 ID
# 設定此值可加速指令註冊（無需等待 Discord API 同步）
# 範例: 123456789012345678
GUILD_ID=your_guild_id_here

# ----------------------------------------
# 資料庫設定 (可選)
# ----------------------------------------

# 資料庫連線 URL
# 支援格式：
#   - SQLite: 不需要設定此變數（預設使用 SQLite）
#   - PostgreSQL: postgresql://user:password@host:port/database
#   - MySQL: mysql://user:password@host:port/database
# 範例: postgresql://postgres:password@localhost:5432/discord_bot
# DATABASE_URL=

# ----------------------------------------
# 環境與日誌設定 (可選)
# ----------------------------------------

# 環境模式
# 選項：development, production, test
# 預設: development
NODE_ENV=development

# 日誌級別
# 選項：debug, info, warn, error
# 預設: info
# 建議：development 使用 info，production 使用 warn
LOG_LEVEL=info

# ----------------------------------------
# OpenCode API 設定 (未來擴展用)
# ----------------------------------------

# OpenCode API URL
# 用於連接 OpenCode 服務
# 範例: https://api.opencode.ai
# OPENCODE_API_URL=

# OpenCode API Key
# 用於驗證 OpenCode API 請求
# OPENCODE_API_KEY=

# ----------------------------------------
# 功能開關 (可選)
# ----------------------------------------

# 啟用 Session 自動儲存
# 選項：true, false
# 預設: true
# AUTO_SAVE_SESSION=true

# 啟用任務隊列
# 選項：true, false
# 預設: true
# ENABLE_QUEUE=true

# 預設模型
# 預設: anthropic/claude-sonnet-4-20250514
# DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514

# 預設 Agent
# 預設: general
# DEFAULT_AGENT=general
